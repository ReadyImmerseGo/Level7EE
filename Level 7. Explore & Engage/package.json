{
  "name": "@speedernetsphere/viewer",
  "version": "5.7.5",
  "type": "module",
  "description": "Viewer application for SpeedernetSphere.",
  "main": "index.html",
  "exports": {
    "default": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "author": "Speedernet",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "bash tools/build/compilation.sh",
    "build:ci": "bash tools/build/compilation-pipeline.sh",
    "clean": "bash tools/build/clean.sh"
  },
  "bundledDependencies": [
    "@speedernet/event",
    "@speedernetsphere/common",
    "@speedernetsphere/core",
    "three"
  ],
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@speedernet/event": "^0.2.3",
    "@speedernet/logger": "^0.4.1",
    "@speedernet/logger-pino": "^2.0.0",
    "@speedernet/plugin": "^1.0.3",
    "@speedernetsphere/common": "*",
    "@speedernetsphere/core": "*",
    "@types/express": "^4.17.17",
    "@types/node": "^20.12.2",
    "@types/three": "~0.180.0",
    "glob": "^11.0.3",
    "rollup": "^4.16.4",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dotenv": "^0.5.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "sass": "^1.75.0",
    "three": "~0.180.0",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "node-remote": "http://localhost:3000",
  "window": {
    "id": "ViewerSphere",
    "title": "SpeedernetSphereViewer",
    "width": 960,
    "height": 640,
    "icon": "static/assets/icons/icon-32x32.png",
    "exe_icon": "static/assets/icons/icon-32x32.png",
    "position": "center",
    "transparent": false,
    "always-on-top": false,
    "fullscreen": false,
    "show_in_taskbar": true,
    "frame": true,
    "show": true
  },
  "chromium-args": "--allow-file-access-from-files --ignore-certificate-errors --disable-site-isolation-trials --disable-web-security",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
